# ── DeskProxy Enterprise – Environment Configuration ──────────────────────
# Copy this file to .env and customise for your deployment.
# All variables have sensible defaults; only override what you need.

# ── Paths ──────────────────────────────────────────────────────────────────
# BASE_DIR=/app                   # Root of the project (default: repo root)
# DATA_DIR_NAME=data              # Subdirectory for SQLite + ChromaDB files
# SQLITE_FILENAME=deskproxy.db    # SQLite database filename
# CHROMA_DIR_NAME=chroma          # ChromaDB persistence subdirectory
# LOG_DIR_NAME=logs               # Log output directory

# ── Embedding model ────────────────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Semantic search ────────────────────────────────────────────────────────
# SIMILARITY_THRESHOLD=0.72       # Cosine similarity cutoff (0.0–1.0)
# CHROMA_COLLECTION=deskproxy_cache
# MAX_CACHE_RESULTS=5             # Max candidates returned per vector query

# ── Analytics cache TTL ────────────────────────────────────────────────────
# ANALYTICS_CACHE_TTL=300         # Seconds before telemetry summary recomputes

# ── Cloud execution simulation ─────────────────────────────────────────────
# CLOUD_MIN_LATENCY_MS=80
# CLOUD_MAX_LATENCY_MS=350

# ── API metadata ───────────────────────────────────────────────────────────
# API_TITLE=DeskProxy Enterprise
# API_VERSION=2.0.0

# ── Logging ────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_JSON=false                  # Set to "true" for structured JSON logs
